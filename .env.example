NEXTSMS_PASSWORD=
NEXTSMS_SENDER_ID=N-SMS
NEXTSMS_USE_TEST_MODE=false

ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=

ZENO_API_URL=https://zenoapi.com/api
ZENO_API_KEY=
